{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-print",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.solenchain.io/**" },
        { "url": "http://127.0.0.1:*/**" }
      ]
    }
  ]
}
